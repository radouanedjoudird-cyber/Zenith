# 🌐 ZENITH CLOUD - EXAMPLE CONFIGURATION
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="mongodb://USER:PASS@HOST:PORT/DB_NAME?replicaSet=rs0"

# Security (JWT)
AT_SECRET="your_ultra_secure_at_secret_here"
RT_SECRET="your_ultra_secure_rt_secret_here"
AT_EXPIRATION="15m"
RT_EXPIRATION="7d"

# Telemetry
LOG_LEVEL=debug