# ---------------------------------------------------------
# ZENITH CLOUD - SECURE INFRASTRUCTURE CONFIGURATION
# ---------------------------------------------------------

# DATABASE CONFIGURATION
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# JWT SECURITY SETTINGS
# SECURITY: Two separate secrets — never use the same value for both.
JWT_SECRET="your-super-secret-access-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"
JWT_EXPIRES_IN="15m"

# APPLICATION SETTINGS
PORT=3000
NODE_ENV="development"

# CORS SECURITY (Whitelist)
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"

# PRISMA OFFLINE ENGINES (Local Infrastructure)
PRISMA_QUERY_ENGINE_LIBRARY="/path/to/engines/libquery_engine.so.node"
PRISMA_SCHEMA_ENGINE_BINARY="/path/to/engines/schema-engine"
PRISMA_QUERY_ENGINE_BINARY="/path/to/engines/query-engine"