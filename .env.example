# -----------------------------------------------------------------------------
# ZENITH CLOUD - SECURE INFRASTRUCTURE CONFIGURATION v4.0 (MongoDB Local)
# -----------------------------------------------------------------------------
# @author Radouane Djoudi
# @description Configuration for local MongoDB development and security vaults.

# 1. DATABASE CONFIGURATION (MongoDB Localhost)
# -----------------------------------------------------------------------------
# Format: mongodb://[username:password@]host[:port]/database
# Note: Ensure MongoDB Community Server is running on port 27017.
DATABASE_URL="mongodb://localhost:27017/zenith_secure_db"

# 2. JWT SECURITY SETTINGS (High-Entropy Vault)
# -----------------------------------------------------------------------------
# CRITICAL: Do not modify these keys in production without rotation protocols.
AT_SECRET="ZENITH_CLOUD_AT_VAULT_2026_STRICT_KEY_#55!"
RT_SECRET="ZENITH_CLOUD_REFRESH_VAULT_2026_STRICT_KEY_#77!"

# 3. EXPIRATION POLICIES
# -----------------------------------------------------------------------------
AT_EXPIRATION="15m"
RT_EXPIRATION="7d"

# 4. APPLICATION SETTINGS
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV="development"

# 5. CORS SECURITY (Whitelist)
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"

# 6. PRISMA OFFLINE ENGINES (Local Infrastructure Paths)
# -----------------------------------------------------------------------------
# These paths are mapped to your HDD for persistent infrastructure integrity.
PRISMA_QUERY_ENGINE_LIBRARY="/media/redone/HDD/zenith/prisma/engines/libquery_engine.so.node"
PRISMA_SCHEMA_ENGINE_BINARY="/media/redone/HDD/zenith/prisma/engines/schema-engine"
PRISMA_QUERY_ENGINE_BINARY="/media/redone/HDD/zenith/prisma/engines/query-engine"