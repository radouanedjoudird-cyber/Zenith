// -----------------------------------------------------------------------------
// 🌐 ZENITH PERSISTENCE LAYER - CORE SCHEMA v6.0 (Enterprise Forensic Edition)
// -----------------------------------------------------------------------------
// @author Radouane Djoudi
// @engine MongoDB with ReplicaSet Optimization
// @security Forensic Fingerprinting & Hardware Identity Mapping
// @status STABLE_RELEASE
// -----------------------------------------------------------------------------

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// [1] SYSTEM ENUMERATIONS
// -----------------------------------------------------------------------------
enum Role {
  ADMIN
  SUPER_ADMIN
  USER
  MANAGER
}

enum LogStatus {
  SUCCESS
  FAILURE
  DENIED
  SUSPICIOUS
  BREACH_ATTEMPT
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// [2] IDENTITY MODELS
// -----------------------------------------------------------------------------

model user {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  email       String   @unique
  password    String
  firstName   String
  familyName  String
  phoneNumber String   @unique
  role        Role     @default(USER)
  createdAt   DateTime @default(now()) @db.Date
  updatedAt   DateTime @updatedAt @db.Date

  // Relation Hooks
  permissions userPermission[]
  sessions    session[]

  @@map("users")
  @@index([role])
}

model session {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hashedRt  String   @unique

  // 🛡️ ENTERPRISE FINGERPRINTING FIELDS
  deviceId  String?  // Unique Hardware/Browser Signature
  os        String?  // Operating System (e.g., Windows 11, Linux)
  browser   String?  // Browser Engine (e.g., Chrome 124, Firefox)
  device    String?  // Device Category (Desktop, Mobile, Tablet)
  cpuArch   String?  // CPU Architecture (x64, arm64)
  
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now()) @db.Date
  updatedAt DateTime @updatedAt @db.Date

  @@map("sessions")
  @@index([userId])
  @@index([deviceId]) // Optimized for session hijacking detection
}

// [3] FORENSIC & TELEMETRY MODELS
// -----------------------------------------------------------------------------

model auditLog {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  action    String
  entity    String
  entityId  String?   @db.ObjectId
  userId    String?   @db.ObjectId
  userEmail String?
  
  // 🛡️ FORENSIC CONTEXT
  deviceId  String?
  os        String?
  browser   String?
  ipAddress String?
  userAgent String?

  // NETWORK & PROTOCOL
  method    String?
  path      String?
  
  // DATA SNAPSHOTS
  payload   Json?     
  newData   Json?     
  oldData   Json?     

  status    LogStatus @default(SUCCESS)
  severity  Severity  @default(LOW)
  createdAt DateTime  @default(now()) @db.Date

  @@map("audit_logs")
  @@index([userId])
  @@index([deviceId])
  @@index([action])
  @@index([severity])
  @@index([createdAt])
}

// [4] GOVERNANCE MODELS
// -----------------------------------------------------------------------------

model userPermission {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   user   @relation(fields: [userId], references: [id], onDelete: Cascade)
  action String

  @@unique([userId, action])
  @@map("user_permissions")
  @@index([action])
}