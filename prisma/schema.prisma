// 🌐 ZENITH PERSISTENCE LAYER - CORE SCHEMA v5.3
// -----------------------------------------------------------------------------
// @author Radouane Djoudi
// @engine MongoDB with ReplicaSet Optimization
// @status FINAL_REVISION_CLEAN
// -----------------------------------------------------------------------------

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// [1] SYSTEM ENUMERATIONS
// -----------------------------------------------------------------------------
enum Role {
  ADMIN
  SUPER_ADMIN
  USER
  MANAGER
}

enum LogStatus {
  SUCCESS
  FAILURE
  DENIED
  SUSPICIOUS
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// [2] IDENTITY MODELS
// -----------------------------------------------------------------------------

model user {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  email       String   @unique // Prisma automatically creates an index for @unique
  password    String
  firstName   String
  familyName  String
  phoneNumber String   @unique // Prisma automatically creates an index for @unique
  role        Role     @default(USER)
  createdAt   DateTime @default(now()) @db.Date
  updatedAt   DateTime @updatedAt @db.Date

  // Relation Hooks
  permissions userPermission[]
  sessions    session[]

  @@map("users")
  @@index([role])
  // Removed @@index([email]) as it is redundant due to @unique
}

model session {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hashedRt  String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now()) @db.Date
  updatedAt DateTime @updatedAt @db.Date

  @@map("sessions")
  @@index([userId])
}

// [3] FORENSIC & TELEMETRY MODELS
// -----------------------------------------------------------------------------

model auditLog {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  action    String
  entity    String
  entityId  String?   @db.ObjectId
  userId    String?   @db.ObjectId
  userEmail String?
  ipAddress String?
  userAgent String?
  method    String?
  path      String?
  
  // METADATA SNAPSHOTS
  payload   Json?     
  newData   Json?     
  oldData   Json?     

  status    LogStatus @default(SUCCESS)
  severity  Severity  @default(LOW)
  createdAt DateTime  @default(now()) @db.Date

  @@map("audit_logs")
  @@index([userId])
  @@index([action])
  @@index([severity])
  @@index([createdAt])
}

// [4] GOVERNANCE MODELS
// -----------------------------------------------------------------------------

model userPermission {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   user   @relation(fields: [userId], references: [id], onDelete: Cascade)
  action String

  @@unique([userId, action])
  @@map("user_permissions")
  @@index([action])
}