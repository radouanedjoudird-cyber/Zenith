// -----------------------------------------------------------------------------
// ZENITH PERSISTENCE LAYER - CORE SCHEMA v7.4.0
// -----------------------------------------------------------------------------
// @file: schema.prisma
// @version: 7.4.2 (Production Ready - Optimized for MongoDB Sparse Indexes)
// @description: Secure IAM & Forensic Telemetry Architecture.
// @compliance: ISO/IEC 27001, SOC2, GDPR, NIST CSF
// -----------------------------------------------------------------------------

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// [1] SYSTEM ENUMERATIONS (Domain Constants)
// -----------------------------------------------------------------------------

enum AccountStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  DEACTIVATED
  FLAGGED
}

enum LogStatus {
  SUCCESS
  FAILURE
  DENIED
  SUSPICIOUS
  BREACH_ATTEMPT
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// -----------------------------------------------------------------------------
// [2] IDENTITY & ACCESS MANAGEMENT (IAM)
// -----------------------------------------------------------------------------

/// @model User
/// Core identity entity with hardware-bound security telemetry and versioning.
model user {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  
  /// Global unique identifier for identity provisioning.
  email         String        @unique
  
  /// @security Argon2id cryptographic hash.
  password      String        
  
  firstName     String
  familyName    String
  
  /// Contact telemetry - enforced uniqueness for SMS-based MFA.
  phoneNumber   String        @unique
  
  /// SYSTEM_STATE_MANAGEMENT
  status        AccountStatus @default(ACTIVE)
  
  /// Multi-Factor Authentication (MFA) status indicator.
  isTwoFactorEnabled Boolean  @default(false)
  
  /// DYNAMIC_RBAC_INTEGRATION
  roleId        String?       @db.ObjectId
  role          role?         @relation(fields: [roleId], references: [id])
  
  /// IDENTITY_RECOVERY_PROTOCOL
  /// @security SHA-256 hashed recovery artifact.
  /// NOTE: @unique removed to allow Native Sparse Index injection via seed.ts.
  /// This prevents 409 Conflict on multiple NULL values.
  resetPasswordToken   String?       
  
  /// @security Temporal boundary for recovery protocol (TTL).
  resetPasswordExpires DateTime?     @db.Date

  /// CONCURRENCY_CONTROL
  /// Versioning for global session revocation on password rotation.
  version       Int            @default(1)

  /// FORENSIC_TELEMETRY
  lastLoginAt   DateTime?      @db.Date
  createdAt     DateTime       @default(now()) @db.Date
  updatedAt     DateTime       @updatedAt @db.Date

  // RELATION_HOOKS
  permissions   userPermission[]
  sessions      session[]

  @@map("users")
  @@index([roleId])
  @@index([status])
  @@index([email, status])
  
  // CRITICAL: The @@unique([resetPasswordToken]) was removed from here.
  // We enforce uniqueness programmatically via MongoClient in seed.ts
  // to ensure 'sparse: true' is respected at the MongoDB Kernel level.
}

/// @model Role
model role {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique 
  description String?
  permissions String[] 
  users       user[]
  createdAt   DateTime @default(now()) @db.Date
  updatedAt   DateTime @updatedAt @db.Date

  @@map("roles")
}

/// @model Session
model session {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hashedRt  String   @unique
  deviceId  String?  
  os        String?  
  browser   String?  
  device    String?  
  cpuArch   String?  
  ipAddress String?
  userAgent String?
  expiresAt DateTime @db.Date
  createdAt DateTime @default(now()) @db.Date
  updatedAt DateTime @updatedAt @db.Date

  @@map("sessions")
  @@index([userId])
  @@index([deviceId])
  @@index([expiresAt])
}

// -----------------------------------------------------------------------------
// [3] FORENSIC AUDIT TELEMETRY (Immutability Layer)
// -----------------------------------------------------------------------------

model auditLog {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  action      String    
  entity      String    
  entityId    String?   @db.ObjectId
  userId      String?   @db.ObjectId
  userEmail   String?
  deviceId    String?
  os          String?   
  browser     String?   
  ipAddress   String?
  userAgent   String?
  method      String?
  path        String?
  payload     Json?     
  newData     Json?     
  status      LogStatus @default(SUCCESS)
  severity    Severity  @default(LOW)
  createdAt   DateTime  @default(now()) @db.Date

  @@map("audit_logs")
  @@index([userId])
  @@index([action])
  @@index([severity])
  @@index([createdAt])
}

// -----------------------------------------------------------------------------
// [4] PERMISSION OVERRIDES (PBAC)
// -----------------------------------------------------------------------------

model userPermission {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  userId  String @db.ObjectId
  user    user   @relation(fields: [userId], references: [id], onDelete: Cascade)
  action  String 

  @@unique([userId, action])
  @@map("user_permissions")
  @@index([action])
}