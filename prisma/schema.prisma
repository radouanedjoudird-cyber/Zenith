// -----------------------------------------------------------------------------
// ZENITH CLOUD ARCHITECTURE - ADVANCED FORENSIC ENGINE v5.0
// -----------------------------------------------------------------------------
// @author Radouane Djoudi
// @project Zenith Secure Engine (Enterprise Edition)

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ==========================================
// IDENTITY & SECURITY ENUMS
// ==========================================
enum Role {
  USER
  ADMIN
  MODERATOR
  SUPER_ADMIN
}

enum LogStatus {
  SUCCESS
  FAILURE
  DENIED
  SUSPICIOUS
}

enum Severity {
  LOW      // INFO: Regular operations
  MEDIUM   // WARN: Important changes
  HIGH     // CRITICAL: Sensitive changes (Passwords, Roles)
  CRITICAL // SECURITY_ALERT: Potential breach or system-wide changes
}

// ==========================================
// USER CORE IDENTITY
// ==========================================
model User {
  id           String           @id @default(auto()) @map("_id") @db.ObjectId
  email        String           @unique
  password     String
  firstName    String
  familyName   String
  phoneNumber  String?          @unique
  role         Role             @default(USER)
  
  sessions     Session[]        
  permissions  UserPermission[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@map("users")
  @@index([role])
}

// ==========================================
// SESSION REGISTRY (Multi-Device Management)
// ==========================================
model Session {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  hashedRt  String   @unique
  userAgent String?
  ipAddress String?
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("sessions")
}

// ==========================================
// PERMISSION SYSTEM (PBAC)
// ==========================================
model UserPermission {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  action  String 
  userId  String @db.ObjectId
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, action]) 
  @@index([action])
  @@map("user_permissions")
}

// ==========================================
// ADVANCED FORENSIC AUDIT TRAIL
// ==========================================
/**
 * @model AuditLog
 * @description Advanced forensic record for full system traceability.
 * Features state snapshotting (Before/After) for critical data mutations.
 */
model AuditLog {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  
  // ACTION METADATA
  action       String   // e.g., "USER_UPDATE", "LOGIN", "PASSWORD_CHANGE"
  path         String?  // The API endpoint accessed
  method       String?  // GET, POST, PATCH, DELETE
  
  // RESOURCE TRACING
  entity       String   // e.g., "User", "Session"
  entityId     String?  // The specific ID of the modified record
  
  // IDENTITY CONTEXT
  userId       String?  @db.ObjectId
  userEmail    String?  
  
  // PAYLOAD SNAPSHOTTING (The "Advanced" Logic)
  payload      Json?    // The raw data sent by the user
  previousData Json?    // State BEFORE mutation (for Forensics/Rollback)
  newData      Json?    // State AFTER mutation
  
  // SECURITY TELEMETRY
  ipAddress    String?
  userAgent    String?
  status       LogStatus @default(SUCCESS)
  severity     Severity  @default(LOW)
  
  createdAt    DateTime @default(now())

  @@map("audit_logs")
  @@index([userId])
  @@index([action])
  @@index([severity])
  @@index([createdAt])
  @@index([entity, entityId]) // Compound index for fast resource history lookup
}