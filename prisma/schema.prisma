// -----------------------------------------------------------------------------
// ZENITH PERSISTENCE LAYER - CORE SCHEMA v7.4.0
// -----------------------------------------------------------------------------
// @file: schema.prisma
// @author: Radouane Djoudi
// @engine: MongoDB with ReplicaSet Optimization
// @standards: ISO/IEC 27001 | SOC2 Compliance | NIST CSF
// -----------------------------------------------------------------------------

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// [1] SYSTEM ENUMERATIONS
// -----------------------------------------------------------------------------

enum AccountStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  DEACTIVATED
  FLAGGED
}

enum LogStatus {
  SUCCESS
  FAILURE
  DENIED
  SUSPICIOUS
  BREACH_ATTEMPT
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// -----------------------------------------------------------------------------
// [2] IDENTITY & ACCESS MANAGEMENT (IAM)
// -----------------------------------------------------------------------------

/// @model User
/// Core identity entity with hardware-bound security telemetry.
model user {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  
  /// Global unique identifier for identity
  email           String        @unique
  password        String        // Argon2id Hashed
  firstName       String
  familyName      String
  phoneNumber     String        @unique
  
  /// SYSTEM_STATE_MANAGEMENT
  status          AccountStatus @default(ACTIVE)
  isTwoFactorEnabled Boolean    @default(false)
  
  /// DYNAMIC_RBAC_INTEGRATION
  roleId          String?       @db.ObjectId
  role            role?         @relation(fields: [roleId], references: [id])
  
  /// IDENTITY_RECOVERY_PROTOCOL
  resetPasswordToken   String?  
  resetPasswordExpires DateTime? @db.Date

  /// CONCURRENCY_CONTROL
  version         Int           @default(1)

  createdAt       DateTime      @default(now()) @db.Date
  updatedAt       DateTime      @updatedAt @db.Date

  // RELATION_HOOKS
  permissions     userPermission[]
  sessions        session[]

  @@map("users")
  @@index([roleId])
  @@index([status])
  @@index([resetPasswordToken])
}

/// @model Role
model role {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique 
  description String?
  permissions String[] 
  
  users       user[]
  createdAt   DateTime @default(now()) @db.Date
  updatedAt   DateTime @updatedAt @db.Date

  @@map("roles")
}

/// @model Session
/// Distributed session management with hardware fingerprinting.
model session {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  hashedRt  String   @unique

  /// HARDWARE_TELEMETRY_ANCHORING
  deviceId  String?  
  os        String?  
  browser   String?  
  device    String?  
  cpuArch   String?  
  
  ipAddress String?
  userAgent String?
  
  expiresAt DateTime @db.Date
  createdAt DateTime @default(now()) @db.Date
  updatedAt DateTime @updatedAt @db.Date

  @@map("sessions")
  @@index([userId])
  @@index([deviceId])
  @@index([expiresAt])
}

// -----------------------------------------------------------------------------
// [3] FORENSIC AUDIT TELEMETRY
// -----------------------------------------------------------------------------

/// @model AuditLog
/// Immutable record of all critical system mutations.
model auditLog {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  action      String    // Format: DOMAIN.ACTION (e.g., USER.PASSWORD_CHANGE)
  entity      String    // Target Domain Object
  entityId    String?   @db.ObjectId
  userId      String?   @db.ObjectId
  userEmail   String?
  
  /// SECURITY_FORENSICS_CONTEXT
  /// 🛡️ FIXED: Added missing hardware telemetry vectors
  deviceId    String?
  os          String?   // 🛡️ Added to match AuditInterceptor
  browser     String?   // 🛡️ Added to match AuditInterceptor
  ipAddress   String?
  userAgent   String?

  method      String?
  path        String?
  
  payload     Json?     
  newData     Json?     
  
  status      LogStatus @default(SUCCESS)
  severity    Severity  @default(LOW)
  createdAt   DateTime  @default(now()) @db.Date

  @@map("audit_logs")
  @@index([userId])
  @@index([action])
  @@index([severity])
  @@index([createdAt])
}

// -----------------------------------------------------------------------------
// [4] PERMISSION OVERRIDES (PBAC)
// -----------------------------------------------------------------------------

model userPermission {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  userId  String @db.ObjectId
  user    user   @relation(fields: [userId], references: [id], onDelete: Cascade)
  action  String 

  @@unique([userId, action])
  @@map("user_permissions")
  @@index([action])
}