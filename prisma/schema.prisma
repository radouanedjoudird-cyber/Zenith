// ZENITH CLOUD - DATABASE SCHEMA v1.1
// VERSION CONTROL: RBAC Implementation Phase
// -----------------------------------------------------------------------------
// SECURITY STRATEGY:
// 1. ISOLATION: Decoupling DB entities from application logic via @@map.
// 2. DATA INTEGRITY: Strict Enum-based Role Management (RBAC).
// 3. AUDITABILITY: Automated timestamping for forensic session analysis.
// 4. PERFORMANCE: Optimized Binary Targets for multi-environment deployment.

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * RBAC ENUMERATION:
 * Defines the strict privilege hierarchy within the system.
 */
enum Role {
  USER
  ADMIN
  MODERATOR
}

model User {
  id           Int      @id @default(autoincrement())

  /**
   * IDENTITY MANAGEMENT:
   * Unique constraint indexed for high-performance authentication lookups.
   */
  email        String   @unique

  /**
   * CREDENTIAL SECURITY:
   * Stores high-entropy Bcrypt hashes. Raw passwords never touch the persistence layer.
   */
  password     String

  firstName    String
  familyName   String

  /**
   * ANTI-SYBIL PROTECTION:
   * Unique phone constraint to prevent mass-automated account creation.
   */
  phoneNumber  String   @unique

  /**
   * RBAC STRATEGY:
   * Enforces the Principle of Least Privilege (PoLP) by defaulting to 'USER'.
   */
  role         Role     @default(USER)

  /**
   * TOKEN ROTATION & REVOCATION:
   * Stores hashed refresh tokens to secure sessions even during DB compromise.
   */
  hashedRt     String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}