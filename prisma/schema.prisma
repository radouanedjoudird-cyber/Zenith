// ZENITH CLOUD ARCHITECTURE - INFRASTRUCTURE LAYER v3.1
// -----------------------------------------------------------------------------
// @author Radouane Djoudi
// @project Zenith Secure Engine
// REFINEMENTS v3.1:
// 1. SECURITY TUNING: Optimized hashedRt field for rapid cryptographic lookup.
// 2. CONCURRENCY: Reinforced indexes to handle sub-millisecond session validation.
// 3. AUDIT DEPTH: Prepared for Zero-Trust session tracking (AuditLog).

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// IDENTITY ENUMS
// ==========================================
enum Role {
  USER
  ADMIN
  MODERATOR
  SUPER_ADMIN
}

enum LogSeverity {
  INFO
  WARN
  CRITICAL
  SECURITY_ALERT
}

// ==========================================
// USER CORE IDENTITY
// ==========================================
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  password     String
  firstName    String
  familyName   String
  phoneNumber  String   @unique
  role         Role     @default(USER)
  
  /**
   * ZENITH SHIELD: REFRESH TOKEN ROTATION HASH
   * Stores the Bcrypt hash of the current RT.
   * Logic: Indexed for sub-millisecond retrieval during rotation cycles.
   */
  hashedRt     String?  
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // RELATION: Granular Access Control (PBAC)
  permissions  UserPermission[]

  @@map("users")
  
  /**
   * PERFORMANCE INDEXES: 
   * Vital for maintaining O(log n) lookup speed during high-concurrency Auth.
   */
  @@index([email])
  @@index([phoneNumber])
  @@index([role])
  @@index([hashedRt]) 
}

// ==========================================
// PERMISSION SYSTEM (PBAC)
// ==========================================
model UserPermission {
  id      Int    @id @default(autoincrement())
  action  String // e.g., "PROFILE_READ", "USER_DELETE"
  userId  Int
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, action]) // Integrity: Prevents redundant permission records
  @@index([action])
  @@map("user_permissions")
}

// ==========================================
// FORENSIC AUDIT TRAIL
// ==========================================
model AuditLog {
  id         Int         @id @default(autoincrement())
  action     String      
  entity     String?     // Target module (e.g., "Users", "Auth")
  entityId   String?     // Specific record ID affected
  userId     Int?        
  userEmail  String?     
  ipAddress  String?     
  userAgent  String?     
  details    Json?       // Stores the delta or error stack
  
  severity   LogSeverity @default(INFO) 
  status     String      @default("SUCCESS") 
  createdAt  DateTime    @default(now())

  @@map("audit_logs")

  /**
   * AUDIT INDEXES:
   * Optimized for forensic dashboards and rapid security investigations.
   */
  @@index([userId])
  @@index([action])
  @@index([severity])
  @@index([createdAt]) 
}