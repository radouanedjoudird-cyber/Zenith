// -----------------------------------------------------------------------------
// ZENITH CLOUD ARCHITECTURE - INFRASTRUCTURE LAYER v4.1 (MongoDB Edition)
// -----------------------------------------------------------------------------
// @author Radouane Djoudi
// @project Zenith Secure Engine
// REFINEMENTS v4.1:
// 1. MIGRATION: Optimized for MongoDB BSON structure.
// 2. BUG FIX: Resolved P1012 by removing redundant indexes on unique fields.
// 3. PERFORMANCE: Leveraged native MongoDB indexing for role-based queries.
// 4. STORAGE: Local persistent storage architecture for HP-ProBook.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ==========================================
// IDENTITY ENUMS
// ==========================================
enum Role {
  USER
  ADMIN
  MODERATOR
  SUPER_ADMIN
}

enum LogSeverity {
  INFO
  WARN
  CRITICAL
  SECURITY_ALERT
}

// ==========================================
// USER CORE IDENTITY
// ==========================================
model User {
  /**
   * PRIMARY IDENTITY: MongoDB BSON ObjectId.
   * Mapping local "_id" to Prisma "id" for standard API consumption.
   */
  id           String           @id @default(auto()) @map("_id") @db.ObjectId
  email        String           @unique // Auto-indexed by MongoDB via @unique
  password     String
  firstName    String
  familyName   String
  phoneNumber  String           @unique // Auto-indexed by MongoDB via @unique
  role         Role             @default(USER)
  
  /**
   * ZENITH SHIELD: REFRESH TOKEN ROTATION HASH
   * Stores the Bcrypt hash of the current RT.
   */
  hashedRt     String?  
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // RELATION: Granular Access Control (PBAC)
  permissions  UserPermission[]

  @@map("users")
  
  /**
   * PERFORMANCE INDEXES: 
   * We only index non-unique fields here. 
   * MongoDB automatically manages unique indexes for Email and PhoneNumber.
   */
  @@index([role])
  @@index([hashedRt]) 
}

// ==========================================
// PERMISSION SYSTEM (PBAC)
// ==========================================
model UserPermission {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  action  String // e.g., "PROFILE_READ", "USER_DELETE"
  
  /**
   * FOREIGN KEY RELATIONSHIP:
   * Must use @db.ObjectId to match the User model's ID type.
   */
  userId  String @db.ObjectId
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, action]) 
  @@index([action])
  @@map("user_permissions")
}

// ==========================================
// FORENSIC AUDIT TRAIL
// ==========================================
model AuditLog {
  id         String      @id @default(auto()) @map("_id") @db.ObjectId
  action     String      
  entity     String?     // Target module (e.g., "Users", "Auth")
  entityId   String?     // Specific record ID affected
  
  /**
   * AUDIT TRACEABILITY:
   * Relational link preserved for strict forensic continuity.
   */
  userId     String?     @db.ObjectId
  userEmail  String?     
  ipAddress  String?     
  userAgent  String?     
  details    Json?       // MongoDB native JSON support
  
  severity   LogSeverity @default(INFO) 
  status     String      @default("SUCCESS") 
  createdAt  DateTime    @default(now())

  @@map("audit_logs")

  /**
   * AUDIT INDEXES:
   * Optimized for forensic dashboards and security telemetry.
   */
  @@index([userId])
  @@index([action])
  @@index([severity])
  @@index([createdAt]) 
}