// ZENITH CLOUD ARCHITECTURE - DATABASE PERSISTENCE LAYER v1.2
// -----------------------------------------------------------------------------
// INFRASTRUCTURE DESIGN:
// 1. RBAC: Strict privilege hierarchy via PostgreSQL Enums.
// 2. FORENSICS: AuditLog system for administrative event tracking.
// 3. SECURITY: PII (Personally Identifiable Information) unique indexing.

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * PRIVILEGE HIERARCHY (RBAC)
 * Defines the core access levels for system authorization.
 */
enum Role {
  USER
  ADMIN
  MODERATOR
}

/**
 * CORE IDENTITY MODEL
 * -------------------
 * Stores primary user metadata and session verification hashes.
 */
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  password     String
  firstName    String
  familyName   String
  phoneNumber  String   @unique
  
  // POLICY: Default to USER to enforce 'Principle of Least Privilege'
  role         Role     @default(USER)
  
  // SESSION SECURITY: Stores Bcrypt hash of the Refresh Token
  hashedRt     String?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

/**
 * AUDIT LOGGING SYSTEM (FORENSICS)
 * --------------------------------
 * Captures critical system state changes and security-sensitive actions.
 * Used for compliance and troubleshooting in production environments.
 */
model AuditLog {
  id             Int      @id @default(autoincrement())
  action         String   // e.g., "SIGNUP", "PRIVILEGE_ESCALATION", "INFRA_DELETE"
  entity         String?  // Target module
  entityId       String?  // ID of the affected resource
  userId         Int?     // Actor ID
  userEmail      String?  
  ipAddress      String?  // Originating IP
  userAgent      String?  // Client/Browser signature
  metadata       Json?    // Detailed payload comparison
  status         String   @default("SUCCESS") // Outcome: [SUCCESS, FAILURE, DENIED]
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}