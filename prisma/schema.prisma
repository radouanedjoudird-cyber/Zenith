// ZENITH CLOUD - DATABASE SCHEMA v1.0
// SECURITY STRATEGY: 
// 1. Isolation: Using @@map to decouple DB table names from application logic.
// 2. Integrity: Strict unique constraints on sensitive identifiers.
// 3. Performance: Strategic indexing for fast lookup and DoS mitigation.

generator client {
  provider      = "prisma-client-js"
  // Added "linux-musl-openssl-3.0.x" if you plan to use Docker later
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  
  // SECURITY: Normalization and unique constraint prevents account duplication
  email       String   @unique
  
  // SECURITY: Hashed password storage (Bcrypt 12)
  password    String
  
  firstName   String
  familyName  String
  
  // SECURITY: Phone numbers should be unique to prevent "Sybil Attacks" (fake multiple accounts)
  phoneNumber String   @unique

  // AUDIT TRAIL: Essential for forensics in case of a security breach
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /**
   * DATABASE MAPPING
   * Decoupling the model name in NestJS (User) from the table name (users).
   * This is a standard practice to hide internal code naming from DB admins.
   */
  @@map("users")
}