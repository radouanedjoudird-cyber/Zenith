// ZENITH CLOUD ARCHITECTURE - DATABASE PERSISTENCE LAYER v1.3
// -----------------------------------------------------------------------------
// IMPROVEMENTS:
// 1. SYNC: Renamed 'metadata' to 'details' to match Guard implementation.
// 2. MONITORING: Added 'severity' for high-priority security alerts.
// 3. PERFORMANCE: Optimized indexes for forensics querying.

generator client {
  provider = "prisma-client-js"
  // Keep binaryTargets for your HP ProBook (Linux) and potential Docker deployments
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  MODERATOR
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  password     String
  firstName    String
  familyName   String
  phoneNumber  String   @unique
  role         Role     @default(USER)
  hashedRt     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model AuditLog {
  id           Int      @id @default(autoincrement())
  action       String   // e.g., "UNAUTHORIZED_ACCESS_ATTEMPT", "SIGNUP"
  entity       String?  
  entityId     String?  
  userId       Int?     
  userEmail    String?  
  ipAddress    String?  
  userAgent    String?  
  
  // FIXED: Renamed from metadata to details to resolve TypeScript errors in Guards
  details      Json?    
  
  // NEW: Categorize logs for fast response (INFO, WARN, CRITICAL)
  severity     String   @default("INFO") 
  
  status       String   @default("SUCCESS") 
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([severity]) // New index for security monitoring
  @@index([createdAt])
  @@map("audit_logs")
}