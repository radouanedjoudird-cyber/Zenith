// -----------------------------------------------------------------------------
// ZENITH CLOUD ARCHITECTURE - MULTI-DEVICE IDENTITY REGISTRY v5.0
// -----------------------------------------------------------------------------
// @author Radouane Djoudi
// @project Zenith Secure Engine (Enterprise Edition)
// REFINEMENTS v5.0:
// 1. SESSION_ISOLATION: Migrated 'hashedRt' to a dedicated 'Session' model.
// 2. CRYPTO_COMPLIANCE: Fully optimized for Argon2id hash storage.
// 3. MULTI_DEVICE: Enabled concurrent sessions with independent rotation cycles.
// 4. SECURITY_ORCHESTRATION: Integrated Device/IP telemetry for audit tracing.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ==========================================
// IDENTITY ENUMS
// ==========================================
enum Role {
  USER
  ADMIN
  MODERATOR
  SUPER_ADMIN
}

enum LogSeverity {
  INFO
  WARN
  CRITICAL
  SECURITY_ALERT
}

// ==========================================
// USER CORE IDENTITY
// ==========================================
model User {
  id           String           @id @default(auto()) @map("_id") @db.ObjectId
  email        String           @unique
  password     String
  firstName    String
  familyName   String
  phoneNumber  String?          @unique
  role         Role             @default(USER)
  
  /**
   * ZENITH SESSIONS REGISTRY:
   * Array of active cryptographic contexts across multiple devices.
   */
  sessions     Session[]        
  
  permissions  UserPermission[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@map("users")
  @@index([role])
}

// ==========================================
// SESSION REGISTRY (Multi-Device Management)
// ==========================================
/**
 * @model Session
 * @description Manages active identity contexts for concurrent devices.
 * Implements granular Refresh Token Rotation (RTR) per device.
 */
model Session {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  
  /**
   * HIGH-ENTROPY HASH: 
   * Argon2id hash of the device-specific Refresh Token.
   */
  hashedRt  String   @unique
  
  // DEVICE TELEMETRY: Forensic metadata for session identification.
  userAgent String?  // e.g., "Mozilla/5.0 (iPhone; CPU iPhone OS 17...)"
  ipAddress String?  // Client origin IP
  
  // RELATION: Linked to the master identity.
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("sessions")
}

// ==========================================
// PERMISSION SYSTEM (PBAC)
// ==========================================
model UserPermission {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  action  String 
  
  userId  String @db.ObjectId
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, action]) 
  @@index([action])
  @@map("user_permissions")
}

// ==========================================
// FORENSIC AUDIT TRAIL
// ==========================================
model AuditLog {
  id         String      @id @default(auto()) @map("_id") @db.ObjectId
  action     String      
  entity     String?     
  entityId   String?     
  
  userId     String?     @db.ObjectId
  userEmail  String?     
  ipAddress  String?     
  userAgent  String?     
  details    Json?       
  
  severity   LogSeverity @default(INFO) 
  status     String      @default("SUCCESS") 
  createdAt  DateTime    @default(now())

  @@map("audit_logs")

  @@index([userId])
  @@index([action])
  @@index([severity])
  @@index([createdAt]) 
}